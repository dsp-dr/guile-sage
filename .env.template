# guile-sage environment configuration
# Copy this file to .env and customize as needed

# Provider: ollama (default), gemini, or openai
SAGE_PROVIDER=ollama

# ===== Local Ollama (default) =====
# For local ollama server on your network
SAGE_OLLAMA_HOST=http://mac.lan:11434
SAGE_MODEL=qwen3-coder:latest

# ===== Cloud Ollama =====
# For ollama.com cloud API with larger models
# Uncomment these and comment out local config above
# OLLAMA_API_KEY=your-ollama-api-key
# SAGE_OLLAMA_HOST=https://api.ollama.com
# SAGE_MODEL=qwen3-coder:480b

# ===== Gemini =====
# SAGE_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key-here
# SAGE_MODEL=gemini-2.0-flash-exp

# ===== OpenAI =====
# SAGE_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key-here
# SAGE_MODEL=gpt-4o
