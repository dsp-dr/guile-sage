# guile-sage environment configuration
# Copy this file to .env and customize as needed

# ============================================================
# PROVIDER CONFIGURATION
# ============================================================

# Provider: ollama (default)
SAGE_PROVIDER=ollama

# ============================================================
# LOCAL OLLAMA - FREE
# ============================================================
# Default configuration for local ollama server
SAGE_OLLAMA_HOST=http://localhost:11434
SAGE_MODEL=qwen3-coder:latest
# Token limit: 32K for qwen3-coder

# ============================================================
# CLOUD OLLAMA (ollama.com) - PAID
# ============================================================
# Uncomment to use Ollama Cloud API
# WARNING: Cloud usage costs money per token!

# SAGE_OLLAMA_HOST=https://api.ollama.com
# OLLAMA_API_KEY=your-ollama-cloud-api-key

# GLM-4.7 Cloud - 128K context window
# SAGE_MODEL=glm-4.7:cloud

# GLM-4.6 Cloud - 200K context window
# SAGE_MODEL=glm-4.6:cloud

# ============================================================
# TOKEN LIMITS & SAFETY
# ============================================================

# Override automatic token limit detection
# SAGE_TOKEN_LIMIT=4000

# Maximum tokens per request (safety cap)
# SAGE_MAX_TOKENS_PER_REQUEST=8000

# ============================================================
# SESSION & STORAGE (XDG Compliant)
# ============================================================

# Override default XDG directories
# SAGE_CONFIG_DIR=~/.config/sage
# SAGE_DATA_DIR=~/.local/share/sage
# SAGE_CACHE_DIR=~/.cache/sage
# SAGE_SESSION_DIR=~/.local/share/sage/sessions

# ============================================================
# BEHAVIOR
# ============================================================

# YOLO mode - allow all tools without confirmation
# WARNING: Enables write_file, eval_scheme, git_commit, etc.
# SAGE_YOLO_MODE=1

# Debug mode - verbose logging
# SAGE_DEBUG=1

# ============================================================
# OBSERVABILITY (OTLP / OpenTelemetry) - new in 0.6.0
# ============================================================
#
# When the OTLP endpoint resolves, sage emits cumulative counters
# for sessions, token usage (model + input/output), tool decisions,
# active time, and (placeholder) cost. Metrics land in Prometheus
# with `exported_job=guile-sage` and surface on the AI Tools
# Multi-Provider dashboard alongside Claude Code, Gemini CLI, etc.
#
# See docs/TELEMETRY.org for the full manual verification harness.
#
# Either set the metrics URL directly...
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=${OTEL_HTTP_ENDPOINT}/v1/metrics
#
# ...or set the base endpoint and sage will derive :4318/v1/metrics
# from it (substituting :4317 -> :4318 if you point at the gRPC port).
# OTEL_EXPORTER_OTLP_ENDPOINT=${OTEL_EXPORTER_OTLP_ENDPOINT}
#
# Resource attributes (key=value,key=value) propagate to every metric.
# host.name, team, sefaca.* etc. are passed through verbatim.
# OTEL_RESOURCE_ATTRIBUTES=host.name=mini,team=aygp-dr
#
# Disable telemetry entirely (tests / CI / offline)
# SAGE_TELEMETRY_DISABLE=1

# ============================================================
# HTTP DEBUG LOGGING (bidirectional wire capture) - new in 0.6.0
# ============================================================
#
# When set, every HTTP request that flows through sage's util.scm
# (Ollama API, OTLP collector, future MCP) is dumped to
# .logs/http.jsonl as JSONL: request body, response body / chunks,
# status code, elapsed time. Lets you verify protocol compliance
# against the wire without rebuilding requests by hand.
# Authorization headers are auto-redacted.
#
# SAGE_DEBUG_HTTP=1
#
# Disable the 8192-byte body truncation (forensic captures only)
# SAGE_DEBUG_HTTP_FULL=1
#
# Override the log directory (defaults to $cwd/.logs)
# SAGE_LOG_DIR=/var/log/sage

# ============================================================
# ALTERNATIVE PROVIDERS
# ============================================================

# Gemini (direct — no guardrails)
# SAGE_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key
# SAGE_MODEL=gemini-2.0-flash-exp

# OpenAI / LiteLLM (guardrails via proxy)
# SAGE_PROVIDER=openai
# SAGE_OPENAI_BASE=http://localhost:4000/v1
# SAGE_OPENAI_API_KEY=your-litellm-key
# SAGE_MODEL=gemini-2.5-flash

# ============================================================
# GUARDRAIL VISIBILITY
# ============================================================
#
# When set, sage warns at startup if the active provider is NOT
# routed through the LiteLLM proxy (i.e., guardrails are bypassed).
# The actual guardrail policies live in LiteLLM config — sage does
# not implement content filtering. This is observability only.
#
# SAGE_GUARDRAIL_PROXY=http://localhost:4000
