# guile-sage environment configuration
# Copy this file to .env and customize as needed

# Provider: ollama (default), gemini, or openai
SAGE_PROVIDER=ollama

# Model (optional, uses provider default if not set)
# For ollama: llama3.2, qwen3-coder, etc.
# SAGE_MODEL=qwen3-coder:latest

# Ollama host (runs locally, no API key needed)
SAGE_OLLAMA_HOST=http://host.lan:11434

# Gemini API key (optional, for gemini provider)
# GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API key (optional, for openai provider)
# OPENAI_API_KEY=your-openai-api-key-here
