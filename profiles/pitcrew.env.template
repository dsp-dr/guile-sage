# Pitcrew Agent — Ecommerce Production Support
# Copy to pitcrew.env and fill in your virtual key.
#
# Usage:
#   cp profiles/pitcrew.env.template profiles/pitcrew.env
#   # edit pitcrew.env with your key
#   source profiles/pitcrew.env && gmake run
#
# Model ladder (all through LiteLLM, all guardrailed):
#   ollama-llama3.2      free, default, fast
#   ollama-qwen2.5-coder free, code-focused
#   deepseek-coder-v2    free, deep analysis
#   gemini-2.5-flash     cloud, $0.30/1M in, $2.50/1M out

SAGE_PROVIDER=openai
SAGE_OPENAI_BASE=http://192.168.86.22:4000/v1
SAGE_OPENAI_API_KEY=<your-litellm-virtual-key>
SAGE_MODEL=gemini-2.5-flash
SAGE_MCP_DISABLE=1
SAGE_STREAMING=0
