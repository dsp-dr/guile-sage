# Temporary build artifacts
.tmp/

# Core dumps
*.core

# Environment (contains secrets)
.env

# Logs
.logs/

# Guile compiled files
*.go

# Emacs
*~
\#*\#
.#*

# Generated output (images, etc.)
output/

# Git worktrees (parallel development branches)
worktrees/

# Sage tool-call demo / project hygiene
pwned.txt
tmp/

# Generated showcase images (promoted copies live in images/)
tests/fixtures/showcase/

