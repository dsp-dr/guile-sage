tests/fixtures/test-*.png

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
__pycache__/
experiments/

# Beads runtime state — treated as local by `bd`, synced via `bd dolt push`
# to a separate Dolt remote. Tracking in git creates a second source of truth
# that drifts, and historical entries contain real contributor emails.
# Keep .beads/config.yaml and .beads/README.md tracked (safe metadata).
.beads/issues.jsonl
.beads/interactions.jsonl
.beads/backup/
.beads/embeddeddolt/
.beads/push-state.json
